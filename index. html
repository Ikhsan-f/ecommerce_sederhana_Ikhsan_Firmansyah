<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kuliner Nusantara</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background-color: #fffaf5;
      color: #333;
    }

    header {
      background-color: #c0392b;
      color: white;
      padding: 20px;
      text-align: center;
    }

    nav {
      background-color: #e74c3c;
      display: flex;
      justify-content: center;
      gap: 20px;
      padding: 10px;
    }

    nav a {
      color: white;
      text-decoration: none;
      font-weight: bold;
    }

    nav a:hover {
      text-decoration: underline;
    }

    .hero {
      height: 300px;
      background: url('https://via.placeholder.com/1200x300') no-repeat center/cover;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 32px;
      font-weight: bold;
    }

    .container {
      padding: 40px;
    }

    .products {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }

    .card {
      background: white;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      overflow: hidden;
      text-align: center;
      transition: transform 0.3s;
    }

    .card:hover {
      transform: scale(1.05);
    }

    .card img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    .card h3 {
      margin: 15px 0;
    }

    .price {
      color: #c0392b;
      font-weight: bold;
      margin-bottom: 15px;
    }

    .btn {
      display: inline-block;
      margin-bottom: 15px;
      padding: 10px 20px;
      background: #e74c3c;
      color: white;
      text-decoration: none;
      border-radius: 5px;
    }

    footer {
      background-color: #c0392b;
      color: white;
      text-align: center;
      padding: 20px;
      margin-top: 40px;
    }
  </style>
</head>
<body>

  <header>
    <h1>Kuliner Nusantara</h1>
    <p>Lezat, Higienis, dan Terpercaya</p>
  </header>

  <nav>
    <a href="#">Home</a>
    <a href="#produk">Produk</a>
    <a href="#kontak">Kontak</a>
  </nav>

  <section class="hero">
    Nikmati Kelezatan Kuliner Terbaik!
  </section>

  <section class="container" id="produk">
    <h2 style="text-align:center; margin-bottom:30px;">Produk Kami</h2>
    <div class="products">

      <div class="card">
        <img src="nasi goreng.jpg" alt="Produk 1">
        <h3>Nasi Goreng Spesial</h3>
        <p class="price">Rp 25.000</p>
        <a href="#" class="btn">Beli</a>
      </div>

      <div class="card">
        <img src="ayam bakso.jpg" alt="Produk 2">
        <h3>Mie Ayam Bakso</h3>
        <p class="price">Rp 20.000</p>
        <a href="#" class="btn">Beli</a>
      </div>

      <div class="card">
        <img src="ayam bakar madu.jpg" alt="Produk 3">
        <h3>Ayam Bakar Madu</h3>
        <p class="price">Rp 30.000</p>
        <a href="#" class="btn">Beli</a>
      </div>

      <div class="card">
        <img src="sate ayam.jpg" alt="Produk 4">
        <h3>Sate Ayam</h3>
        <p class="price">Rp 22.000</p>
        <a href="#" class="btn">Beli</a>
      </div>

    </div>
  </section>

  <section class="container" id="kontak">
    <h2 style="text-align:center; margin-bottom:20px;">Kontak Kami</h2>
    <p style="text-align:center;">Email: info@kuliner.com | Telp: 0812-3456-7890</p>
  </section>

  <footer>
    <p>&copy; 2026 Kuliner Nusantara. All Rights Reserved.</p>
  </footer>

</body>
</html>
